data/representations/*.npy filter=lfs diff=lfs merge=lfs -text
data/representations/*.parquet filter=lfs diff=lfs merge=lfs -text

# Normalize text files to LF in the repository.
* text=auto

# Source code and project files should use LF on every platform.
*.py  text eol=lf
*.sh  text eol=lf
*.md  text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.gitignore text eol=lf
.gitattributes text eol=lf

# Binary data must never undergo line-ending conversion.
*.npy binary
*.parquet binary
*.pt binary
*.pth binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
